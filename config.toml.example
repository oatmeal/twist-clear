[twitch]
# Scraper credentials — create a Confidential app at https://dev.twitch.tv/console/apps.
client_id     = "your_client_id_here"
client_secret = "your_client_secret_here"

# (Optional) Client ID for the browser "Login with Twitch" feature.
# Must be a SEPARATE Public app (no client_secret) — browser OAuth requires a
# Public client type. Create a second app and set its Client Type to "Public".
# Register your redirect URIs WITHOUT a trailing slash, e.g.:
#   http://localhost:5173
#   http://localhost:4173
#   https://you.github.io/my-clips
# If omitted, the "Login with Twitch" button is hidden in the viewer.
# web_client_id = "your_public_app_client_id_here"

[frontend]
# Title prefix shown in the browser tab and page heading.
# Streamer names from the database are appended automatically at runtime,
# e.g. "My Archive: streamer1, streamer2".
# site_title = "twist-clear clip archive"

# Optional subtitle shown below the title in the page header (hidden on mobile).
# Omit or leave empty to show nothing.
# site_description = "A clip archive for streamer_one and streamer_two"

# Text for the og:description meta tag (social link previews).
# og_description = "A Twitch clip archive."

# Canonical URL for the og:url meta tag. Auto-computed in CI from the GitHub
# Pages URL; set here if deploying to a custom domain.
# site_url = "https://you.github.io/my-clips/"

# ── Colour overrides ──────────────────────────────────────────────────────
# All values accept any valid CSS colour: hex, hsl(), oklch(), etc.
# Omit a key to keep the built-in default. Partial overrides are fine.
# See docs/theming.md for tips, contrast guidance, and example palettes.

# Accent: interactive highlights, buttons, calendar heat-map.     Default: #9147ff
# accent_color = "#9147ff"

# Page background.                                                Default: #0e0e0e
# color_bg = "#0e0e0e"

# Card and header background.                                     Default: #1f1f23
# color_surface = "#1f1f23"

# Dropdowns, nav buttons, secondary surfaces.                     Default: #26262c
# color_surface2 = "#26262c"

# Borders and dividers.                                           Default: #3a3a40
# color_border = "#3a3a40"

# Primary text.                                                   Default: #efeff1
# color_text = "#efeff1"

# Secondary text and labels.                                      Default: #adadb8
# color_muted = "#adadb8"

# Calendar heat-map colour — intentionally separate from accent_color so the
# density ramp reads as data rather than interactive UI. Default: #22a84a (green).
# Set to match accent_color if you want them to track together.
# cal_accent_color = "#22a84a"

[scraper]
db_path = "data/clips.db"

# Add one [[streamers]] block per channel you want to track.
[[streamers]]
login = "streamer_one"

[[streamers]]
login = "streamer_two"
